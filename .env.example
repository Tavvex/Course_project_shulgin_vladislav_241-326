SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///site.db
FLASK_ENV=development

# Почта для отправки писем восстановления пароля (необязательно).
# Если не заполнить, письма не отправляются, но сайт продолжит работать.
ALERT_EMAIL_FROM=
ALERT_EMAIL_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
